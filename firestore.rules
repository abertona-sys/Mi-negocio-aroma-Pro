rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: Verifica si el usuario está autenticado
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper: Verifica si el usuario autenticado coincide con el storeId/dueño
    function isOwner(storeId) {
      return isSignedIn() && request.auth.uid == storeId;
    }

    // --- REGLAS PARA STORES ---
    match /stores/{storeId} {
      allow read: if true;
      allow create, update: if isOwner(storeId);
    }

    // --- REGLAS PARA PRODUCTOS ---
    match /products/{productId} {
      allow read: if true;
      allow create, update: if isSignedIn() && request.resource.data.storeId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.storeId == request.auth.uid;
    }

    // --- REGLAS PARA MATERIALES ---
    match /materials/{materialId} {
      allow read: if isSignedIn() && resource.data.storeId == request.auth.uid;
      allow create, update: if isSignedIn() && request.resource.data.storeId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.storeId == request.auth.uid;
    }

    // --- REGLAS PARA PEDIDOS/ORDENES ---
    match /orders/{orderId} {
      allow create: if true;
      allow read, update, delete: if isSignedIn() && resource.data.storeId == request.auth.uid;
    }
  }
}
