rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    // Global Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    // Validate ID length & characters
    function isValidId(id) { 
        return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }

    // --- Store Validation ---
    function isValidStoreProfile(data) {
      return data.keys().hasAll(['storeName', 'phone', 'ownerId', 'createdAt'])
        && data.storeName is string && data.storeName.size() <= 100
        && data.phone is string && data.phone.size() <= 50
        && data.ownerId == request.auth.uid
        && (data.description == null || (data.description is string && data.description.size() <= 500));
    }

    // --- Product Validation ---
    function isValidProduct(data) {
      return data.keys().hasAll(['storeId', 'name', 'category', 'price', 'isActive', 'createdAt'])
        && data.storeId is string && data.storeId.size() > 0
        && data.name is string && data.name.size() > 0 && data.name.size() <= 200
        && data.category is string && data.category in ['sachet', 'melt', 'squeeze']
        && data.price is number && data.price >= 0
        && data.isActive is bool
        && (data.imageUrl == null || (data.imageUrl is string && data.imageUrl.size() <= 2000));
    }

    // --- Material Validation ---
    function isValidMaterial(data) {
      return data.keys().hasAll(['storeId', 'name', 'quantity', 'unit'])
        && data.storeId == request.auth.uid
        && data.name is string && data.name.size() > 0 && data.name.size() <= 200
        && data.quantity is number && data.quantity >= 0
        && data.unit is string && data.unit.size() <= 50;
    }

    // --- Order Validation ---
    function isValidOrder(data) {
      return data.keys().hasAll(['storeId', 'customerName', 'customerPhone', 'items', 'total', 'status', 'createdAt'])
        && data.storeId is string && data.storeId.size() > 0
        && data.customerName is string && data.customerName.size() > 0 && data.customerName.size() <= 100
        && data.customerPhone is string && data.customerPhone.size() > 0 && data.customerPhone.size() <= 50
        && data.items is list && data.items.size() > 0 && data.items.size() <= 50
        && data.total is number && data.total >= 0
        && data.status is string && data.status in ['pending', 'completed', 'cancelled'];
    }

    // --- Collections ---

    match /stores/{storeId} {
      allow read: if true; // Public can read store info
      allow create: if isSignedIn() && storeId == request.auth.uid && isValidStoreProfile(incoming()) && incoming().createdAt == request.time;
      allow update: if isSignedIn() && storeId == request.auth.uid && isValidStoreProfile(incoming()) && incoming().createdAt == existing().createdAt;
    }

    match /products/{productId} {
      // Anyone can read products (for the public catalog)
      allow read: if true;
      allow create: if isSignedIn() && incoming().storeId == request.auth.uid && isValidId(productId) && isValidProduct(incoming()) && incoming().createdAt == request.time;
      allow update: if isSignedIn() && existing().storeId == request.auth.uid && incoming().storeId == request.auth.uid && isValidId(productId) && isValidProduct(incoming()) && incoming().createdAt == existing().createdAt;
      allow delete: if isSignedIn() && existing().storeId == request.auth.uid;
    }

    match /materials/{materialId} {
      // Admin only
      allow read: if isSignedIn() && existing().storeId == request.auth.uid;
      allow create: if isSignedIn() && incoming().storeId == request.auth.uid && isValidId(materialId) && isValidMaterial(incoming());
      allow update: if isSignedIn() && existing().storeId == request.auth.uid && incoming().storeId == request.auth.uid && isValidId(materialId) && isValidMaterial(incoming());
      allow delete: if isSignedIn() && existing().storeId == request.auth.uid;
    }

    match /orders/{orderId} {
      // Admin can read their own orders
      allow read: if isSignedIn() && existing().storeId == request.auth.uid;
      // Anyone can create an order (public checkout)
      allow create: if isValidId(orderId) && isValidOrder(incoming()) && incoming().createdAt == request.time && incoming().status == 'pending';
      // Admin can update orders
      allow update: if isSignedIn() && existing().storeId == request.auth.uid && incoming().storeId == request.auth.uid && isValidId(orderId) && isValidOrder(incoming()) && incoming().createdAt == existing().createdAt;
      allow delete: if isSignedIn() && existing().storeId == request.auth.uid;
    }
  }
}
