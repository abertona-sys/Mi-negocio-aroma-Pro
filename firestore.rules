rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    // Global Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    // --- Collections ---

    match /stores/{storeId} {
      allow read: if true;
      allow create, update: if isSignedIn() && storeId == request.auth.uid;
    }

    match /products/{productId} {
      allow read: if true;
      allow create, update: if isSignedIn() && request.resource.data.storeId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.storeId == request.auth.uid;
    }

    match /materials/{materialId} {
      allow read: if isSignedIn() && resource.data.storeId == request.auth.uid;
      allow create, update: if isSignedIn() && request.resource.data.storeId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.storeId == request.auth.uid;
    }

    match /orders/{orderId} {
      allow create: if true;
      allow read, update, delete: if isSignedIn() && resource.data.storeId == request.auth.uid;
    }
  }
}
